[ALIGMENT: 16B]

HEADER:
	MAGIC: "NDR\0"
	VERSION: 4B
	RESERVED: 4B
	HEADER_CHECKSUM: 4B
	TOTAL_SIZE: 8B
	RESERVED: 8B
REGISTRY_TABLE:
	NUMBER_OF_ENTRIES: 8B
	RESERVED: 4B
	REGISTRY_TABLE_CHECKSUM: 4B
	REPEAT NUMBER_OF_ENTRIES {
		ENTRY_ID: 8B
		ENTRY_OFFSET: 8B
		ROOT_ID: 8B
		RESERVED: 8B
	}

REGISTRY_ENTRY:
	ENTRY_SIZE_IN_BYTES: 8B
	ENTRY_ID: 8B
	ENTRY_NAME_SIZE: 8B
	RESERVED: 8B
	ENTRY_NAME: NB
	ENTRY_TYPE: 4B (
		R_NODE: 0
		R_NUMERIC: 1
		R_UTF8: 2
		R_UTF16: 3
		R_NULL: UINT16_MAX
	)
	RESERVED: 4B
	ENTRY_FLAGS: 4B
	ENTRY_DATA: NB
ALIGMENT