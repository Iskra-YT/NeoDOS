{
    "langrev": "1",
    "sources": ["src/**"],
    "c-sources": [ "csource/**" ],
    "output": "build",
    "warnings": ["no-unused"],
    "opt": "O0",
    "targets": {
        "kernel": {
            "type": "executable",
            "target": "elf-x64",
            "no-entry": true,
            "cpu": "x86_64",
            "use-stdlib": false,
            "strip-unused": false
        }
    }
}
